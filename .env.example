# Browser-safe variables. Configure these in Netlify for production.
VITE_SUPABASE_URL="https://yznrtdzxtbbmfsqlkwds.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
# Optional extra anti-spam layer. Leave unset until a Cloudflare Turnstile widget exists.
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# Server-only Edge Function secrets (never prefix these with VITE_):
# CONTACT_RATE_LIMIT_SALT (required by the Edge Function)
# TURNSTILE_SECRET_KEY (optional, enable together with VITE_TURNSTILE_SITE_KEY)
# TURNSTILE_ALLOWED_HOSTNAMES
